# Actual Budget server connection
ACTUAL_SERVER_URL=https://your-actual-server.com
ACTUAL_SERVER_PASSWORD=your-actual-password
ACTUAL_SYNC_ID=your-budget-sync-id-from-settings

# Local data directory for cached budget files (default: ./data)
ACTUAL_DATA_DIR=./data

# Path to SQLite DB for OAuth token persistence (default: {ACTUAL_DATA_DIR}/auth.db)
# AUTH_DB_PATH=./data/auth.db

# MCP server OAuth - password shown to user in the browser login form
MCP_AUTH_PASSWORD=choose-a-strong-password

# JWT signing secret - must be at least 32 characters
JWT_SECRET=replace-with-a-random-string-at-least-32-chars

# HTTP server settings
PORT=3000
BASE_URL=https://your-mcp-domain.com

# Paperless-NGX document archival (optional)
# PAPERLESS_URL=https://your-paperless-server.com
# PAPERLESS_TOKEN=your_api_token
# PAPERLESS_RECEIPT_TAG_ID=1
# Custom field IDs (set only the fields you've created in Paperless-NGX)
# PAPERLESS_FIELD_PAYEE=1
# PAPERLESS_FIELD_ACCOUNT_ID=2
# PAPERLESS_FIELD_ACCOUNT_NAME=3
# PAPERLESS_FIELD_TRANSACTION_ID=4
# PAPERLESS_FIELD_TRANSACTION_DATE=5
